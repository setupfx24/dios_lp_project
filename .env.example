# Root-level env consumed by docker-compose. Copy to `.env` to override defaults.

# Postgres bootstrap user (only for the first container start; lp_owner / lp_app /
# lp_readonly are created by infra/docker/postgres-init/01-create-roles.sql).
POSTGRES_BOOTSTRAP_PW=bootstrap_pw

# Application Postgres roles. lp_app is the runtime user; lp_owner is for migrations only.
LP_OWNER_PW=owner_pw
LP_APP_PW=changeme_in_compose_env
LP_RO_PW=ro_pw

# JWT secret for the dashboard / admin sessions. MUST be ≥32 chars in production.
JWT_SECRET=devsecret_at_least_32_characters_long

# pgAdmin login (only used in dev compose).
PGADMIN_PW=admin

# --- Admin auth ---
# MUST differ from JWT_SECRET — broker and admin trust domains must not share a secret.
ADMIN_JWT_SECRET=devadminsecret_at_least_32_characters_long
TOTP_ENCRYPTION_KEY=devkey_at_least_32_characters_long_for_aes_gcm

# Single-binary dev: ROUTES_ENABLED=all. Production split: run two api instances
# with broker/admin respectively.
ROUTES_ENABLED=all
