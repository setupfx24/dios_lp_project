# =============================================================================
# .env.production.example — API runtime config for PRODUCTION DEPLOYMENT.
#
# READ THIS BEFORE FIRST DEPLOY:
#
# 1. The values below were generated by `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
#    at the moment this file was created. They are FOR EXAMPLE PURPOSES ONLY.
#    Generate fresh values for your deployment — never copy a checked-in value
#    into a live environment.
#
# 2. The schema in src/config/env.schema.ts enforces:
#    - JWT_SECRET, COOKIE_SECRET, ADMIN_JWT_SECRET, TOTP_ENCRYPTION_KEY each ≥32 chars
#    - COOKIE_SECRET ≠ JWT_SECRET ≠ ADMIN_JWT_SECRET (no shared trust domains)
#    - CORS_ORIGINS must be set when NODE_ENV=production
#    - None of the *_SECRET values may match the .env.example placeholders
#
# 3. Rotate DATABASE_URL's password by:
#    a. Generating a fresh LP_APP_PW
#    b. Passing `-c lp.app_pw=$LP_APP_PW -c lp.ro_pw=$LP_RO_PW` to Postgres
#    c. Running `pnpm db:migrate` against lp_owner — migration 0001 ALTERs the
#       lp_app + lp_readonly role passwords to the GUC value
#    d. Updating DATABASE_URL here to point at the new password
#
# 4. Set ADMIN_SEED_PASSWORD ≥12 chars before running `pnpm tsx infra/scripts/seed.ts`.
#    The seed script will refuse to run with a placeholder or short value.
# =============================================================================

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Database ---
# lp_app is the runtime role with no DDL and no UPDATE/DELETE on append-only
# tables (trades, ledger_entries, audit_logs). lp_owner is migration-only.
# Replace HOST + PASSWORD with your real Postgres endpoint.
DATABASE_URL=postgres://lp_app:REPLACE_WITH_LP_APP_PW@postgres.internal:5432/lp
DATABASE_POOL_MAX=20

# --- Redis ---
REDIS_URL=redis://redis.internal:6379

# --- Secrets — REGENERATE for your environment ---
JWT_SECRET=9juDMyUWygwMBngN35Y2zWRT6Lc3v_W78gR4r6KOm-JWdRY09lHM-o_nBrksw-Ei
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECRET=gfzNjnYpudtfN7qXf3I2S2TDqW6K4qiXM-kFRMsFrpEeTHf51jVTvFx1Osnx5q2U
ADMIN_JWT_SECRET=ZS3aXUdt7UQJLbpmRhT9T6wIKoKoSymgRZ4SKKiJYcvmmVptQPOOVWsdWJAb9Sfg
ADMIN_JWT_EXPIRY=15m
TOTP_ENCRYPTION_KEY=ePAlcMuWClTbRmosQyrNfXkBnp8MAMM-KJgPObfxmrlDYcf7eSeNuK5f5zPCEnf-
TOTP_ISSUER=LP Platform

# --- CORS — must list your real public origins (no defaults in prod) ---
# Schema refuses startup if NODE_ENV=production and this is unset/empty.
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- HMAC broker auth ---
HMAC_REPLAY_WINDOW_MS=30000

# --- OpenAPI ---
# Set false in prod unless you mean to expose /docs publicly.
SWAGGER_ENABLED=false

# --- Route gating ---
#   - "broker": public api instance (HMAC + JWT user auth)
#   - "admin":  private admin api instance (TOTP + reauth + 4-eyes)
#   - "all":    single binary serves both
ROUTES_ENABLED=all

# --- Admin policy knobs ---
ADMIN_REAUTH_WINDOW_SECONDS=300
ADMIN_4EYES_THRESHOLD_PAISE=1000000
ADMIN_IDLE_TIMEOUT_SECONDS=900
