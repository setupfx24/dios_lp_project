# API runtime config. Copy to .env (and to .env.test for the test runner).

NODE_ENV=development
PORT=3000

# Postgres — runtime user is lp_app (no DDL, no UPDATE/DELETE on append-only tables).
# The owner role lp_owner is used only for migrations.
DATABASE_URL=postgres://lp_app:lp_app_pw@localhost:5432/lp
DATABASE_POOL_MAX=20

# Redis (BullMQ + pub/sub for the websocket gateway).
REDIS_URL=redis://localhost:6379

# JWT for dashboard users.  MUST be at least 32 chars in production.
JWT_SECRET=devsecret_at_least_32_characters_long
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# HMAC replay window for broker requests.
HMAC_REPLAY_WINDOW_MS=30000

LOG_LEVEL=info

# Comma-separated. Used by CORS.
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

SWAGGER_ENABLED=true

# --- Route gating ---
# Which controller groups this binary serves. "all" mounts both broker and admin.
# Production may run two instances: one with ROUTES_ENABLED=broker (public),
# one with ROUTES_ENABLED=admin (private subnet only).
ROUTES_ENABLED=all

# --- Admin auth ---
# MUST be different from JWT_SECRET above (separate cookie, separate trust domain).
ADMIN_JWT_SECRET=devadminsecret_at_least_32_characters_long
ADMIN_JWT_EXPIRY=15m

# Set ONLY when the trade/admin UIs and API are on different subdomains, to a
# shared parent domain (leading dot) so every app can read its auth cookie.
# Leave unset for single-host/localhost deploys. e.g. prod: .swistrade.com
# Applies to BOTH broker and admin cookies. (ADMIN_COOKIE_DOMAIN = legacy alias.)
# COOKIE_DOMAIN=

# Window during which a fresh password re-entry "unlocks" sensitive admin actions.
ADMIN_REAUTH_WINDOW_SECONDS=300

# 4-eyes threshold in paise. Default ₹10,000 = 10_00_000 paise. Wallet adjustments
# and charge rate changes above this go to a pending_actions queue for second
# admin approval. Self-approval is rejected by the backend.
ADMIN_4EYES_THRESHOLD_PAISE=1000000

# Admin sessions auto-expire if no request arrives within this many seconds.
ADMIN_IDLE_TIMEOUT_SECONDS=900

# AES-256-GCM passphrase for encrypting TOTP secrets at rest. MUST be supplied
# from a secret manager in production; rotation requires a re-encrypt migration.
TOTP_ENCRYPTION_KEY=devkey_at_least_32_characters_long_for_aes_gcm

TOTP_ISSUER=LP Platform
