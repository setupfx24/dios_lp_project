{
  "name": "@lp/api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "db:generate": "drizzle-kit generate --config=src/database/drizzle.config.ts",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:studio": "drizzle-kit studio --config=src/database/drizzle.config.ts"
  },
  "dependencies": {
    "@lp/constants": "workspace:*",
    "@lp/core": "workspace:*",
    "@lp/types": "workspace:*",
    "@lp/utils": "workspace:*",
    "@lp/validators": "workspace:*",
    "@fastify/cookie": "9.4.0",
    "@fastify/helmet": "12.0.0",
    "@nestjs/bullmq": "10.2.1",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/event-emitter": "2.0.4",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/platform-fastify": "10.4.4",
    "@nestjs/platform-socket.io": "10.4.4",
    "@nestjs/swagger": "7.4.2",
    "@nestjs/websockets": "10.4.4",
    "argon2": "0.41.1",
    "bullmq": "5.13.2",
    "drizzle-orm": "0.34.1",
    "fastify": "4.28.1",
    "ioredis": "5.4.1",
    "nestjs-pino": "4.1.0",
    "otplib": "12.0.1",
    "qrcode": "1.5.4",
    "pg": "8.13.0",
    "pino": "9.4.0",
    "pino-http": "10.3.0",
    "pino-pretty": "11.2.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "socket.io": "4.8.0",
    "ulid": "2.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@lp/eslint-config": "workspace:*",
    "@lp/tsconfig": "workspace:*",
    "@types/node": "20.16.10",
    "@types/pg": "8.11.10",
    "@types/qrcode": "1.5.5",
    "drizzle-kit": "0.25.0",
    "eslint": "9.11.1",
    "rimraf": "6.0.1",
    "testcontainers": "10.13.1",
    "tsx": "4.19.1",
    "typescript": "5.6.2",
    "vitest": "2.1.1"
  }
}
