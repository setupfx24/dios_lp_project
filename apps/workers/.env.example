NODE_ENV=development
DATABASE_URL=postgres://lp_app:lp_app_pw@localhost:5432/lp
DATABASE_POOL_MAX=10
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

# S3 used by audit-archive.processor in production. Leave blank to use the no-op driver in dev.
S3_BUCKET=
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
